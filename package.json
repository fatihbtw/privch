{
    "name": "privch",
    "version": "0.3.2",
    "scripts": {
        "dev:lint": "eslint .",
        "dev:prettiercheck": "prettier . --check",
        "dev:prettier": "prettier . --write",
        "dev:check": "eslint . && prettier . --check",
        "build:setup-node": "tsc && node build/src/setup_node.js",
        "build:css": "postcss ./templates/styles.css -o ./public/styles.min.css",
        "build:ts": "tsc",
        "build:front": "cd front && npm i && npm run build",
        "build:all": "postcss ./templates/styles.css -o ./public/styles.min.css && tsc && cd front && npm i && npm run build",
        "start": "node build/src/index.js",
        "start:dev": "tsc && node build/src/index.js"
    },
    "devDependencies": {
        "@types/express": "^4.17.17",
        "@types/node": "^18.15.11",
        "@types/ws": "^8.5.5",
        "autoprefixer": "^10.4.14",
        "daisyui": "^2.51.5",
        "eslint": "^8.46.0",
        "postcss": "^8.4.21",
        "postcss-cli": "^10.1.0",
        "prettier": "^2.8.7",
        "tailwindcss": "^3.3.1",
        "typescript": "^5.0.4"
    },
    "dependencies": {
        "axios": "^1.3.5",
        "eta": "^2.0.1",
        "express": "^4.18.2",
        "m3u8-parser": "^7.1.0",
        "ws": "^8.13.0"
    }
}
